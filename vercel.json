{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/meta_report",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{tmp/**,output/**,deploy/**,campaigns/**,campaign-sets/**,work/**,__pycache__/**,scripts/__pycache__/**,$CODEX_HOME/**}"
    }
  }
}
